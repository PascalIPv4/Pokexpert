# PokeExpert FR Scan Bot — Variables d'environnement
# Copiez ce fichier en .env et renseignez vos clés

# API Pokémon TCG (gratuit sur https://dev.pokemontcg.io/)
# Sans clé : 1 000 requêtes/jour. Avec clé : 20 000 requêtes/jour.
POKEMON_TCG_API_KEY=

# Anthropic Claude Vision (optionnel — améliore la précision d'identification)
# Récupérable sur https://console.anthropic.com/
ANTHROPIC_API_KEY=
